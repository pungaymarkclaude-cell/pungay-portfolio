body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: black;
    color: white;
    line-height: 1.6;
}

/* HEADER */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 30px;
    background: #111;
    position: sticky;
    top: 0;
}

.logo {
    font-size: 22px;
    font-weight: bold;
}

nav a {
    margin: 0 10px;
    color: white;
    text-decoration: none;
    transition: 0.3s;
}

nav a:hover {
    color: red;
}

/* HERO */
.hero {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 60px 40px;
    min-height: 80vh;
}

.hero-text h1 {
    font-size: 40px;
    margin-bottom: 10px;
}

.hero-text p {
    margin-bottom: 20px;
}

.hero img {
    width: 280px;
    height: 280px;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid red;
}

/* BUTTON */
button {
    background: red;
    color: white;
    border: none;
    padding: 12px 25px;
    border-radius: 5px;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    background: darkred;
}

/* SECTIONS */
section {
    padding: 50px 40px;
}

h2 {
    color: red;
    margin-bottom: 20px;
}

/* HOBBIES */
.cards {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
}

.card {
    background: #111;
    padding: 15px;
    border-radius: 10px;
    text-align: center;
    width: 250px;
    transition: transform 0.3s;
}

.card:hover {
    transform: translateY(-5px);
}

.card img {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 10px;
}

/* CONTACT */
.socials a {
    margin-right: 15px;
    color: red;
    text-decoration: none;
    transition: 0.3s;
}

.socials a:hover {
    color: white;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 20px;
    background: #111;
}

/* MOBILE */
@media (max-width: 768px) {

    header {
        flex-direction: column;
        text-align: center;
    }

    nav {
        margin-top: 10px;
    }

    .hero {
        flex-direction: column;
        text-align: center;
    }

    .hero img {
        margin-top: 20px;
        width: 220px;
        height: 220px;
    }

    .cards {
        flex-direction: column;
        align-items: center;
    }
}
